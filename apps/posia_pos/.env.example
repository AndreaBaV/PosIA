# Copie este archivo a `.env` en la misma carpeta y reemplace los valores.
# La app lee este archivo al arrancar (Windows/Linux/macOS).
# En release movil use --dart-define si no hay archivo .env.

# URL del hub sync (sin barra final)
POSIA_HUB_URL=ejemplo

# Clave API del hub (misma que API_KEY en server/sync_api)
POSIA_HUB_API_KEY=ejemplo
