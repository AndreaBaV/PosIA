# Hub POSIA en Oracle Always Free + Neon
#
# Copia a .env en server/sync_api/:
#   cp .env.example .env
#
# Dominio para HTTPS (Caddy + Let's Encrypt). Ejemplos gratuitos:
#   - DuckDNS: posia-tuempresa.duckdns.org
#   - Subdominio propio apuntando a la IP pública de Oracle
POSIA_HUB_DOMAIN=posia-tuempresa.duckdns.org

DATABASE_URL=postgresql://USUARIO:CLAVE@ep-xxx.neon.tech/neondb?sslmode=require
API_KEY=genera-una-clave-secreta-larga
POSIA_ENV=production
PORT=8080
