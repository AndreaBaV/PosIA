# Neon PostgreSQL (copiar a .env y completar)
DATABASE_URL=postgresql://USUARIO:CLAVE@ep-xxx.neon.tech/neondb?sslmode=require
API_KEY=genera-una-clave-secreta-larga
POSIA_ENV=production
PORT=8080

# Usuarios admin: INSERT manual en Neon (ver docs/sql/crear_admin_neon.sql)

# En la caja POS (Admin → Sincronizar):
# URL del hub: http://localhost:8080  (dev) o https://tu-api.onrender.com (prod)
# API Key: la misma que API_KEY de arriba
